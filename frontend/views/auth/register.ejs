<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Register - JeevBandhu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>

<body class="bg-gradient-to-br from-emerald-50 via-white to-blue-50 min-h-screen overflow-x-hidden" style="font-family: 'Plus Jakarta Sans', sans-serif;">
    <!-- Animated Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none">
        <div class="absolute -top-40 -right-40 w-96 h-96 bg-emerald-200 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-pulse"></div>
        <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-blue-200 rounded-full mix-blend-multiply filter blur-3xl opacity-20 animate-pulse"></div>
    </div>

    <div class="min-h-screen flex items-center justify-center py-12 px-4 sm:px-6 lg:px-8 relative z-10">
        <div class="max-w-md w-full">
            <!-- Logo & Heading -->
            <div class="text-center mb-12">
                <a href="/" class="inline-flex items-center gap-2 text-3xl font-extrabold gradient-text hover:scale-105 transition-transform duration-300 mb-8">
                    <i class="fas fa-cow text-emerald-600 text-2xl"></i>
                    <span>JeevBandhu</span>
                </a>
                <h2 class="text-4xl font-display font-bold text-gray-900 mb-2">Join the community</h2>
                <p class="text-gray-600">Start managing your livestock with confidence</p>
            </div>

            <form action="/register" method="POST">
                <div class="card-lg">
                    <% if (error) { %>
                        <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-700 rounded-lg flex items-start gap-3">
                            <i class="fas fa-exclamation-circle text-red-600 mt-0.5 flex-shrink-0"></i>
                            <span><%= error %></span>
                        </div>
                    <% } %>

                    <div class="space-y-4">
                        <div>
                            <label for="name" class="form-label">
                                <i class="fas fa-user text-emerald-600 mr-2"></i>Full Name
                            </label>
                            <input id="name" name="name" type="text" required class="input-field"
                                placeholder="John Doe">
                        </div>

                        <div>
                            <label for="email" class="form-label">
                                <i class="fas fa-envelope text-emerald-600 mr-2"></i>Email Address
                            </label>
                            <input id="email" name="email" type="email" required class="input-field"
                                placeholder="you@example.com">
                        </div>

                        <div>
                            <label for="password" class="form-label">
                                <i class="fas fa-lock text-emerald-600 mr-2"></i>Password
                            </label>
                            <input id="password" name="password" type="password" required class="input-field"
                                placeholder="At least 6 characters">
                            <p class="text-xs text-gray-500 mt-1">Must be at least 6 characters long</p>
                        </div>

                        <div>
                            <label for="confirmPassword" class="form-label">
                                <i class="fas fa-lock text-emerald-600 mr-2"></i>Confirm Password
                            </label>
                            <input id="confirmPassword" name="confirmPassword" type="password" required
                                class="input-field" placeholder="Re-enter your password">
                        </div>

                        <div>
                            <label class="form-label mb-3">
                                <i class="fas fa-briefcase text-emerald-600 mr-2"></i>I am a:
                            </label>
                            <div class="grid grid-cols-2 gap-3">
                                <label class="relative">
                                    <input type="radio" name="role" value="farmer" required class="sr-only peer">
                                    <div class="peer-checked:border-emerald-600 peer-checked:bg-emerald-50 border-2 border-gray-200 rounded-lg p-4 text-center cursor-pointer transition-all hover:border-emerald-400">
                                        <i class="fas fa-seedling text-2xl text-emerald-600 mb-2"></i>
                                        <div class="font-semibold text-sm">Farmer</div>
                                    </div>
                                </label>
                                <label class="relative">
                                    <input type="radio" name="role" value="buyer" required class="sr-only peer">
                                    <div class="peer-checked:border-blue-600 peer-checked:bg-blue-50 border-2 border-gray-200 rounded-lg p-4 text-center cursor-pointer transition-all hover:border-blue-400">
                                        <i class="fas fa-shopping-bag text-2xl text-blue-600 mb-2"></i>
                                        <div class="font-semibold text-sm">Buyer</div>
                                    </div>
                                </label>
                            </div>
                        </div>

                        <div class="flex items-start gap-2 pt-2">
                            <input type="checkbox" id="terms" class="w-4 h-4 mt-1" required>
                            <label for="terms" class="text-sm text-gray-600">
                                I agree to the <a href="#" class="text-emerald-600 hover:underline">Terms of Service</a> and <a href="#" class="text-emerald-600 hover:underline">Privacy Policy</a>
                            </label>
                        </div>
                    </div>

                    <div class="mt-8 pt-6">
                        <button type="submit" class="w-full btn-primary btn-lg flex items-center justify-center gap-2">
                            <i class="fas fa-user-plus"></i>
                            <span>Create Account</span>
                        </button>
                    </div>

                    <div class="mt-6 pt-6 border-t border-gray-200 text-center">
                        <p class="text-gray-600">
                            Already have an account?
                            <a href="/login" class="font-bold text-emerald-600 hover:text-emerald-700 transition-colors">
                                Sign in
                            </a>
                        </p>
                    </div>
                </div>
            </form>
        </div>
    </div>
</body>

</html>