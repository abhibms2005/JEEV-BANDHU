<%# Dashboard - Modern Design %>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - JeevBandhu</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&family=Playfair+Display:wght@600;700&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="/css/output.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
</head>

<body class="min-h-screen" style="font-family: 'Plus Jakarta Sans', sans-serif; background: linear-gradient(135deg, #f0fdf4 0%, #ecfdf5 25%, #f0f9ff 50%, #faf5ff 75%, #fff7ed 100%);">
    <!-- Navigation -->
    <nav class="nav-glass">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="flex justify-between items-center h-16">
                <a href="/dashboard" class="flex items-center gap-2.5 group">
                    <div class="w-9 h-9 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-xl flex items-center justify-center shadow-lg group-hover:shadow-emerald-200 transition-shadow">
                        <i class="fas fa-leaf text-white text-sm"></i>
                    </div>
                    <span class="text-xl font-extrabold bg-gradient-to-r from-emerald-700 to-teal-600 bg-clip-text text-transparent" style="-webkit-background-clip:text;-webkit-text-fill-color:transparent;">JeevBandhu</span>
                </a>
                <div class="hidden md:flex items-center space-x-1">
                    <!-- Dashboard -->
                    <a href="/dashboard" class="nav-link-pill"><i class="fas fa-home text-xs"></i> Dashboard</a>

                    <!-- Farm Dropdown -->
                    <div class="dropdown-container">
                        <button class="nav-link-pill dropdown-trigger">
                            <i class="fas fa-seedling text-xs"></i> Farm
                            <i class="fas fa-chevron-down text-[10px] ml-1 dd-arrow"></i>
                        </button>
                        <div class="dropdown-menu">
                            <a href="/animals/add" class="dropdown-item"><i class="fas fa-plus text-emerald-500 w-5"></i> Add Animal</a>
                            <a href="/dashboard" class="dropdown-item"><i class="fas fa-chart-bar text-blue-500 w-5"></i> My Animals</a>
                            <a href="/ai-assistant" class="dropdown-item"><i class="fas fa-robot text-purple-500 w-5"></i> AI Diagnosis</a>
                            <a href="/guide/medicine-guide" class="dropdown-item"><i class="fas fa-capsules text-rose-500 w-5"></i> Medicine Guide</a>
                            <a href="/compliance" class="dropdown-item"><i class="fas fa-shield-alt text-teal-500 w-5"></i> Biosecurity</a>
                        </div>
                    </div>

                    <!-- Commerce Dropdown -->
                    <div class="dropdown-container">
                        <button class="nav-link-pill dropdown-trigger">
                            <i class="fas fa-store text-xs"></i> Commerce
                            <i class="fas fa-chevron-down text-[10px] ml-1 dd-arrow"></i>
                        </button>
                        <div class="dropdown-menu">
                            <a href="/marketplace" class="dropdown-item"><i class="fas fa-shopping-bag text-indigo-500 w-5"></i> Browse Marketplace</a>
                            <a href="/list-product" class="dropdown-item"><i class="fas fa-plus-circle text-emerald-500 w-5"></i> List Product</a>
                            <a href="/my-products" class="dropdown-item"><i class="fas fa-box text-amber-500 w-5"></i> My Products</a>
                            <a href="/orders/sales" class="dropdown-item"><i class="fas fa-receipt text-orange-500 w-5"></i> Sales</a>
                        </div>
                    </div>

                    <!-- Community -->
                    <a href="/community" class="nav-link-pill"><i class="fas fa-users text-xs"></i> Community</a>

                    <!-- User -->
                    <div class="flex items-center ml-3 pl-3 border-l border-gray-200 gap-2">
                        <div class="w-8 h-8 bg-gradient-to-br from-emerald-400 to-teal-500 rounded-full flex items-center justify-center text-white text-xs font-bold shadow-sm">
                            <%= (user.name || 'U').charAt(0).toUpperCase() %>
                        </div>
                        <span class="text-gray-700 font-semibold text-sm"><%= user.name %></span>
                        <form action="/logout" method="POST" class="inline ml-1">
                            <button type="submit" class="text-gray-400 hover:text-red-500 transition-colors text-sm" title="Logout">
                                <i class="fas fa-sign-out-alt"></i>
                            </button>
                        </form>
                    </div>
                </div>

                <!-- Mobile Hamburger -->
                <button id="mobileMenuBtn" class="md:hidden flex flex-col justify-center items-center w-10 h-10 hamburger z-50 relative">
                    <span class="block w-5 h-0.5 bg-gray-700 mb-1 rounded transition-all"></span>
                    <span class="block w-5 h-0.5 bg-gray-700 mb-1 rounded transition-all"></span>
                    <span class="block w-5 h-0.5 bg-gray-700 rounded transition-all"></span>
                </button>
            </div>
        </div>

        <!-- Mobile Menu -->
        <div id="mobileMenu" class="mobile-menu hidden fixed top-16 right-0 h-screen w-80 bg-white shadow-2xl z-40 md:hidden overflow-y-auto">
            <div class="flex flex-col p-5 space-y-1">
                <div class="flex items-center gap-3 p-4 bg-gradient-to-r from-emerald-50 to-teal-50 rounded-xl mb-3">
                    <div class="w-10 h-10 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-full flex items-center justify-center text-white font-bold shadow-md">
                        <%= (user.name || 'U').charAt(0).toUpperCase() %>
                    </div>
                    <div>
                        <p class="font-semibold text-gray-800 text-sm"><%= user.name || 'User' %></p>
                        <p class="text-xs text-emerald-600">Farmer</p>
                    </div>
                </div>
                <a href="/dashboard" class="mobile-nav-item"><i class="fas fa-home text-emerald-500 w-5"></i> Dashboard</a>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider px-4 pt-3 pb-1">Farm</p>
                <a href="/animals/add" class="mobile-nav-item"><i class="fas fa-plus text-emerald-500 w-5"></i> Add Animal</a>
                <a href="/dashboard" class="mobile-nav-item"><i class="fas fa-chart-bar text-blue-500 w-5"></i> My Animals</a>
                <a href="/ai-assistant" class="mobile-nav-item"><i class="fas fa-robot text-purple-500 w-5"></i> AI Diagnosis</a>
                <a href="/guide/medicine-guide" class="mobile-nav-item"><i class="fas fa-capsules text-rose-500 w-5"></i> Medicine Guide</a>
                <a href="/compliance" class="mobile-nav-item"><i class="fas fa-shield-alt text-teal-500 w-5"></i> Biosecurity</a>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider px-4 pt-3 pb-1">Commerce</p>
                <a href="/marketplace" class="mobile-nav-item"><i class="fas fa-shopping-bag text-indigo-500 w-5"></i> Marketplace</a>
                <a href="/list-product" class="mobile-nav-item"><i class="fas fa-plus-circle text-emerald-500 w-5"></i> List Product</a>
                <a href="/my-products" class="mobile-nav-item"><i class="fas fa-box text-amber-500 w-5"></i> My Products</a>
                <a href="/orders/sales" class="mobile-nav-item"><i class="fas fa-receipt text-orange-500 w-5"></i> Sales</a>
                <p class="text-xs font-bold text-gray-400 uppercase tracking-wider px-4 pt-3 pb-1">Social</p>
                <a href="/community" class="mobile-nav-item"><i class="fas fa-users text-blue-500 w-5"></i> Community</a>
                <div class="pt-3 mt-3 border-t border-gray-100">
                    <form action="/logout" method="POST">
                        <button type="submit" class="mobile-nav-item text-red-500 hover:bg-red-50 w-full text-left">
                            <i class="fas fa-sign-out-alt w-5"></i> Logout
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </nav>

    <!-- Main Content -->
    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
        <!-- Header -->
        <div class="mb-10 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
            <div>
                <p class="text-emerald-600 font-semibold text-sm mb-1"><i class="fas fa-chart-line mr-1"></i> Overview</p>
                <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 mb-2">My Herd Dashboard</h1>
                <p class="text-gray-500">Track livestock health, manage records, and stay bio-safe compliant</p>
            </div>
            <a href="/animals/add" class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-emerald-600 to-teal-600 text-white font-semibold rounded-xl hover:shadow-lg hover:shadow-emerald-200 transition-all hover:-translate-y-0.5">
                <i class="fas fa-plus"></i> Add Animal
            </a>
        </div>

        <!-- Stats Grid -->
        <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-5 mb-10">
            <div class="relative overflow-hidden bg-white rounded-2xl p-6 border border-emerald-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-emerald-100 to-transparent rounded-bl-full opacity-60"></div>
                <div class="flex items-start justify-between mb-3 relative">
                    <div>
                        <p class="text-gray-500 text-sm font-medium mb-1">Total Animals</p>
                        <p class="text-3xl font-extrabold text-emerald-600"><%= stats.total %></p>
                    </div>
                    <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-teal-500 rounded-xl flex items-center justify-center text-white text-lg shadow-lg shadow-emerald-200 group-hover:scale-110 transition-transform">
                        <i class="fas fa-cow"></i>
                    </div>
                </div>
                <p class="text-xs text-gray-400 font-medium"><i class="fas fa-arrow-up text-emerald-500"></i> Your herd size</p>
            </div>

            <div class="relative overflow-hidden bg-white rounded-2xl p-6 border border-green-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-green-100 to-transparent rounded-bl-full opacity-60"></div>
                <div class="flex items-start justify-between mb-3 relative">
                    <div>
                        <p class="text-gray-500 text-sm font-medium mb-1">Healthy</p>
                        <p class="text-3xl font-extrabold text-green-600"><%= stats.healthy %></p>
                    </div>
                    <div class="w-12 h-12 bg-gradient-to-br from-green-500 to-emerald-500 rounded-xl flex items-center justify-center text-white text-lg shadow-lg shadow-green-200 group-hover:scale-110 transition-transform">
                        <i class="fas fa-heart"></i>
                    </div>
                </div>
                <p class="text-xs text-gray-400 font-medium"><i class="fas fa-check-circle text-green-500"></i> Ready for production</p>
            </div>

            <div class="relative overflow-hidden bg-white rounded-2xl p-6 border border-red-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-red-100 to-transparent rounded-bl-full opacity-60"></div>
                <div class="flex items-start justify-between mb-3 relative">
                    <div>
                        <p class="text-gray-500 text-sm font-medium mb-1">Withdrawal Lock</p>
                        <p class="text-3xl font-extrabold text-red-600"><%= stats.locked %></p>
                    </div>
                    <div class="w-12 h-12 bg-gradient-to-br from-red-500 to-rose-500 rounded-xl flex items-center justify-center text-white text-lg shadow-lg shadow-red-200 group-hover:scale-110 transition-transform">
                        <i class="fas fa-lock"></i>
                    </div>
                </div>
                <p class="text-xs text-gray-400 font-medium"><i class="fas fa-exclamation-circle text-red-500"></i> Under medication</p>
            </div>

            <div class="relative overflow-hidden bg-white rounded-2xl p-6 border border-amber-100 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 group">
                <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-amber-100 to-transparent rounded-bl-full opacity-60"></div>
                <div class="flex items-start justify-between mb-3 relative">
                    <div>
                        <p class="text-gray-500 text-sm font-medium mb-1">Avg Health Score</p>
                        <p class="text-3xl font-extrabold text-amber-600"><%= stats.avgHealthScore %></p>
                    </div>
                    <div class="w-12 h-12 bg-gradient-to-br from-amber-500 to-orange-500 rounded-xl flex items-center justify-center text-white text-lg shadow-lg shadow-amber-200 group-hover:scale-110 transition-transform">
                        <i class="fas fa-chart-pie"></i>
                    </div>
                </div>
                <p class="text-xs text-gray-400 font-medium"><span class="text-amber-500"><i class="fas fa-star"></i></span> Out of 100</p>
            </div>
        </div>

        <!-- Health Score Breakdown -->
        <div class="card-lg mb-12">
            <div class="flex flex-col md:flex-row items-start md:items-center justify-between mb-6">
                <div>
                    <h2 class="heading-md mb-2"><i class="fas fa-chart-line text-emerald-600 mr-2"></i>Health Score Breakdown</h2>
                    <p class="text-gray-600">Understanding your herd's overall health calculation</p>
                </div>
                <button onclick="toggleHealthInfo()" class="btn-secondary btn-sm mt-4 md:mt-0">
                    <span id="healthInfoIcon"><i class="fas fa-chevron-down"></i></span>
                    <span id="healthInfoText" class="ml-2">View Details</span>
                </button>
            </div>

            <!-- Collapsible Details Panel -->
            <div id="healthInfoPanel" class="hidden">
                <div class="grid md:grid-cols-3 gap-6 mb-6">
                    <!-- Medical History Factor -->
                    <div class="p-6 rounded-xl bg-gradient-to-br from-green-50 to-emerald-50 border border-green-200 hover:shadow-md transition-all">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="icon-box bg-green-100 text-green-600">
                                <i class="fas fa-pills"></i>
                            </div>
                            <h3 class="font-semibold text-lg">Medical History</h3>
                        </div>
                        <p class="text-gray-600 text-sm mb-4">Recent treatments and interventions</p>
                        <div class="w-full bg-gray-200 rounded-full h-2 mb-2">
                            <div class="bg-green-500 h-2 rounded-full" style="width: 85%;"></div>
                        </div>
                        <span class="text-xs text-gray-600">85% • Fewer treatments = better</span>
                    </div>

                    <!-- Withdrawal Compliance Factor -->
                    <div class="p-6 rounded-xl bg-gradient-to-br from-amber-50 to-orange-50 border border-amber-200 hover:shadow-md transition-all">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="icon-box bg-amber-100 text-amber-600">
                                <i class="fas fa-hourglass-end"></i>
                            </div>
                            <h3 class="font-semibold text-lg">Withdrawal Status</h3>
                        </div>
                        <p class="text-gray-600 text-sm mb-4">Medicine withdrawal period tracking</p>
                        <div class="w-full bg-gray-200 rounded-full h-2 mb-2">
                            <div class="bg-amber-500 h-2 rounded-full" style="width: 70%;"></div>
                        </div>
                        <span class="text-xs text-gray-600">70% • No locked animals = optimal</span>
                    </div>

                    <!-- Biosecurity Compliance Factor -->
                    <div class="p-6 rounded-xl bg-gradient-to-br from-blue-50 to-cyan-50 border border-blue-200 hover:shadow-md transition-all">
                        <div class="flex items-center gap-3 mb-4">
                            <div class="icon-box bg-blue-100 text-blue-600">
                                <i class="fas fa-shield-alt"></i>
                            </div>
                            <h3 class="font-semibold text-lg">Biosecurity</h3>
                        </div>
                        <p class="text-gray-600 text-sm mb-4">Safety and compliance measures</p>
                        <div class="w-full bg-gray-200 rounded-full h-2 mb-2">
                            <div class="bg-blue-500 h-2 rounded-full" style="width: <%= stats.biosecurityScore %>%;"></div>
                        </div>
                        <span class="text-xs text-gray-600"><%= stats.biosecurityScore %>% • <a href="/compliance" class="text-emerald-600 hover:underline font-semibold">View Tracker</a></span>
                    </div>
                </div>

                <div class="p-4 rounded-lg bg-emerald-50 border border-emerald-200">
                    <p class="text-sm text-gray-700">
                        <i class="fas fa-lightbulb text-amber-500 mr-2"></i>
                        <span class="font-semibold">Tip:</span> Maintain high biosecurity compliance and keep animals healthy to improve your overall health score.
                    </p>
                </div>
            </div>
        </div>

        <!-- Animals Section -->
        <% if (animals.length===0) { %>
            <div class="card-lg text-center py-16">
                <div class="text-6xl mb-6 text-emerald-600">
                    <i class="fas fa-cow"></i>
                </div>
                <h2 class="heading-md mb-4">No animals yet</h2>
                <p class="text-gray-600 text-lg mb-8 max-w-md mx-auto">Start managing your herd by adding your first animal to the system</p>
                <a href="/animals/add" class="btn-primary btn-lg inline-flex items-center gap-2">
                    <i class="fas fa-plus"></i>
                    Add First Animal
                </a>
            </div>
        <% } else { %>
            <div class="mb-8 flex items-center justify-between">
                <div>
                    <h2 class="heading-md mb-1">Your Herd</h2>
                    <p class="text-gray-600"><%= animals.length %> animal<%= animals.length !== 1 ? 's' : '' %> · <span class="text-emerald-600 font-semibold"><%= stats.healthy %> healthy</span></p>
                </div>
                <a href="/animals/add" class="btn-primary btn-sm">
                    <i class="fas fa-plus mr-2"></i>Add Animal
                </a>
            </div>

            <!-- Herd Grid -->
            <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
                <% animals.forEach((animal, index) => { %>
                    <% const isHealthy = animal.status === 'HEALTHY'; %>
                    <% const isWithdrawal = animal.status === 'WITHDRAWAL_LOCK'; %>
                    <div class="card-lg group hover-lift transition-all duration-300" style="animation: slideIn 0.5s ease-out;">
                        <!-- Card Header -->
                        <div class="flex justify-between items-start mb-5">
                            <div>
                                <h3 class="heading-sm text-gray-900"><%= animal.tagId %></h3>
                                <p class="text-gray-600 text-sm mt-1">
                                    <%= animal.species %><% if (animal.breed) { %> • <%= animal.breed %><% } %>
                                </p>
                            </div>

                            <!-- Status Badge -->
                            <% if (isHealthy) { %>
                                <span class="status-healthy">
                                    <i class="fas fa-check-circle"></i>
                                    Healthy
                                </span>
                            <% } else if (isWithdrawal) { %>
                                <span class="status-locked">
                                    <i class="fas fa-lock"></i>
                                    Locked
                                </span>
                            <% } else { %>
                                <span class="status-quarantine">
                                    <i class="fas fa-exclamation-triangle"></i>
                                    Monitoring
                                </span>
                            <% } %>
                        </div>

                        <!-- Health Score Bar -->
                        <div class="mb-5">
                            <div class="flex justify-between items-end mb-2">
                                <span class="text-gray-600 text-sm font-semibold">Health Score</span>
                                <span class="font-display font-bold text-lg"
                                    style="color: <%= animal.healthScore >= 70 ? '#10b981' : animal.healthScore >= 40 ? '#f59e0b' : '#ef4444' %>">
                                    <%= animal.healthScore %>/100
                                </span>
                            </div>
                            <div class="w-full bg-gray-200 rounded-full h-2.5 overflow-hidden">
                                <div class="h-full transition-all duration-500" 
                                    style="width: <%= animal.healthScore %>%; background: <%= animal.healthScore >= 70 ? '#10b981' : animal.healthScore >= 40 ? '#f59e0b' : '#ef4444' %>;"></div>
                            </div>
                        </div>

                        <!-- Withdrawal Warning / Health Status -->
                        <% if (isWithdrawal && animal.withdrawalEndsAt) { %>
                            <% const now = new Date(); %>
                            <% const diff = new Date(animal.withdrawalEndsAt) - now; %>
                            <% const daysRemaining = Math.max(0, Math.ceil(diff / (1000 * 60 * 60 * 24))); %>
                            <div class="p-3 rounded-lg mb-5 bg-red-50 border border-red-200">
                                <p class="text-red-700 font-semibold text-sm">
                                    <i class="fas fa-clock text-red-600 mr-2"></i><%= daysRemaining %> day<%= daysRemaining !== 1 ? 's' : '' %> remaining
                                </p>
                            </div>
                        <% } else if (isHealthy) { %>
                            <div class="p-3 rounded-lg mb-5 bg-green-50 border border-green-200">
                                <p class="text-green-700 font-semibold text-sm">
                                    <i class="fas fa-check-circle text-green-600 mr-2"></i>Ready for production
                                </p>
                            </div>
                        <% } %>

                        <!-- Action Buttons -->
                        <div class="grid grid-cols-2 gap-3 pt-4 border-t border-gray-200">
                            <a href="/animals/<%= animal._id %>"
                                class="btn-outline btn-sm text-center justify-center text-xs py-2">
                                <i class="fas fa-eye mr-1"></i>View
                            </a>
                            <a href="/animals/<%= animal._id %>/add-medicine"
                                class="btn-secondary btn-sm text-center justify-center text-xs py-2">
                                <i class="fas fa-pills mr-1"></i>Medicine
                            </a>
                            <button onclick="openWeightModal('<%= animal._id %>', '<%= animal.tagId %>')"
                                class="btn-primary btn-sm text-center text-xs py-2">
                                <i class="fas fa-weight mr-1"></i>Weight
                            </button>
                            <button onclick="openFeedModal('<%= animal._id %>', '<%= animal.tagId %>')"
                                class="btn-secondary btn-sm text-center text-xs py-2">
                                <i class="fas fa-leaf mr-1"></i>Feed
                            </button>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </main>

    <!-- Weight Logging Modal -->
    <div id="weightModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black bg-opacity-50">
        <div class="card-lg rounded-2xl max-w-md w-full p-8 shadow-2xl">
            <h2 class="heading-md mb-6 flex items-center gap-2">
                <i class="fas fa-weight text-emerald-600"></i>
                Log Animal Weight
            </h2>
            <form id="weightForm">
                <input type="hidden" id="weightAnimalId">
                <input type="hidden" id="weightAnimalTag">

                <div class="mb-5">
                    <label class="form-label">Weight (kg)</label>
                    <input type="number" id="weightValue" step="0.1" required placeholder="e.g., 500"
                        class="input-field">
                </div>

                <div class="mb-5">
                    <label class="form-label">Date</label>
                    <input type="date" id="weightDate" required
                        class="input-field">
                </div>

                <div class="mb-6">
                    <label class="form-label">Notes (Optional)</label>
                    <textarea id="weightNotes" rows="3" placeholder="Any observations..."
                        class="input-field"></textarea>
                </div>

                <div class="flex gap-3">
                    <button type="button" onclick="closeWeightModal()"
                        class="btn-secondary flex-1">Cancel</button>
                    <button type="submit"
                        class="btn-primary flex-1">Save Weight</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Feed Logging Modal -->
    <div id="feedModal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black bg-opacity-50">
        <div class="card-lg rounded-2xl max-w-md w-full p-8 shadow-2xl">
            <h2 class="heading-md mb-6 flex items-center gap-2">
                <i class="fas fa-leaf text-emerald-600"></i>
                Log Feed Consumption
            </h2>
            <form id="feedForm">
                <input type="hidden" id="feedAnimalId">
                <input type="hidden" id="feedAnimalTag">

                <div class="mb-5">
                    <label class="form-label">Feed Amount (kg)</label>
                    <input type="number" id="feedAmount" step="0.1" required placeholder="e.g., 25"
                        class="input-field">
                </div>

                <div class="mb-5">
                    <label class="form-label">Feed Type</label>
                    <select id="feedType" class="input-field">
                        <option value="Standard Feed">Standard Feed</option>
                        <option value="Protein Mix">Protein Mix</option>
                        <option value="Grains">Grains</option>
                        <option value="Hay">Hay</option>
                        <option value="Silage">Silage</option>
                        <option value="Custom Mix">Custom Mix</option>
                    </select>
                </div>

                <div class="mb-5">
                    <label class="form-label">Date</label>
                    <input type="date" id="feedDate" required
                        class="input-field">
                </div>

                <div class="mb-6">
                    <label class="form-label">Notes (Optional)</label>
                    <textarea id="feedNotes" rows="3" placeholder="Any observations..."
                        class="input-field"></textarea>
                </div>

                <div class="flex gap-3">
                    <button type="button" onclick="closeFeedModal()"
                        class="btn-secondary flex-1">Cancel</button>
                    <button type="submit"
                        class="btn-primary flex-1">Save Feed Record</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        // Initialize date inputs to today
        const today = new Date().toISOString().split('T')[0];
        document.getElementById('weightDate').value = today;
        document.getElementById('feedDate').value = today;

        // Health Score Accordion Toggle
        function toggleHealthInfo() {
            const panel = document.getElementById('healthInfoPanel');
            const icon = document.getElementById('healthInfoIcon');

            if (panel.classList.contains('hidden')) {
                panel.classList.remove('hidden');
                icon.innerHTML = '<i class="fas fa-chevron-up"></i>';
            } else {
                panel.classList.add('hidden');
                icon.innerHTML = '<i class="fas fa-chevron-down"></i>';
            }
        }

        // Weight Modal Functions
        function openWeightModal(animalId, animalTag) {
            document.getElementById('weightAnimalId').value = animalId;
            document.getElementById('weightAnimalTag').value = animalTag;
            document.getElementById('weightModal').classList.remove('hidden');
        }

        function closeWeightModal() {
            document.getElementById('weightModal').classList.add('hidden');
            document.getElementById('weightForm').reset();
            document.getElementById('weightDate').value = today;
        }

        // Feed Modal Functions
        function openFeedModal(animalId, animalTag) {
            document.getElementById('feedAnimalId').value = animalId;
            document.getElementById('feedAnimalTag').value = animalTag;
            document.getElementById('feedModal').classList.remove('hidden');
        }

        function closeFeedModal() {
            document.getElementById('feedModal').classList.add('hidden');
            document.getElementById('feedForm').reset();
            document.getElementById('feedDate').value = today;
        }

        // Close modals when clicking outside
        ['weightModal', 'feedModal'].forEach(modalId => {
            document.getElementById(modalId).addEventListener('click', (e) => {
                if (e.target.id === modalId) {
                    e.target.classList.add('hidden');
                }
            });
        });

        // Weight Form Submission
        document.getElementById('weightForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const data = {
                animalId: document.getElementById('weightAnimalId').value,
                weight: document.getElementById('weightValue').value,
                recordedDate: document.getElementById('weightDate').value,
                notes: document.getElementById('weightNotes').value
            };

            try {
                const response = await fetch('/api/animals/weight', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    closeWeightModal();
                    window.location.reload();
                } else {
                    alert(`❌ ${result.error}`);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('❌ Failed to record weight. Please try again.');
            }
        });

        // Feed Form Submission
        document.getElementById('feedForm').addEventListener('submit', async (e) => {
            e.preventDefault();

            const data = {
                animalId: document.getElementById('feedAnimalId').value,
                feedAmount: document.getElementById('feedAmount').value,
                feedType: document.getElementById('feedType').value,
                feedDate: document.getElementById('feedDate').value,
                notes: document.getElementById('feedNotes').value
            };

            try {
                const response = await fetch('/api/animals/feed', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (result.success) {
                    closeFeedModal();
                    window.location.reload();
                } else {
                    alert(`❌ ${result.error}`);
                }
            } catch (error) {
                console.error('Error:', error);
                alert('❌ Failed to record feed. Please try again.');
            }
        });

        // Dropdown logic
        document.querySelectorAll('.dropdown-container').forEach(container => {
            const trigger = container.querySelector('.dropdown-trigger');
            const menu = container.querySelector('.dropdown-menu');
            const arrow = trigger.querySelector('.dd-arrow');
            let timeout;

            container.addEventListener('mouseenter', () => {
                clearTimeout(timeout);
                menu.classList.add('active');
                if (arrow) arrow.style.transform = 'rotate(180deg)';
            });

            container.addEventListener('mouseleave', () => {
                timeout = setTimeout(() => {
                    menu.classList.remove('active');
                    if (arrow) arrow.style.transform = 'rotate(0deg)';
                }, 150);
            });

            trigger.addEventListener('click', (e) => {
                e.stopPropagation();
                const isActive = menu.classList.contains('active');
                document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.remove('active'));
                if (!isActive) menu.classList.add('active');
            });
        });

        document.addEventListener('click', () => {
            document.querySelectorAll('.dropdown-menu').forEach(m => m.classList.remove('active'));
            document.querySelectorAll('.dd-arrow').forEach(a => a.style.transform = 'rotate(0deg)');
        });

        // Mobile menu
        const mobileMenuBtn = document.getElementById('mobileMenuBtn');
        const mobileMenu = document.getElementById('mobileMenu');
        if (mobileMenuBtn && mobileMenu) {
            mobileMenuBtn.addEventListener('click', () => {
                mobileMenuBtn.classList.toggle('active');
                mobileMenu.classList.toggle('active');
                mobileMenu.classList.toggle('hidden');
            });
            mobileMenu.querySelectorAll('a, button[type="submit"]').forEach(link => {
                link.addEventListener('click', () => {
                    mobileMenuBtn.classList.remove('active');
                    mobileMenu.classList.add('hidden');
                    mobileMenu.classList.remove('active');
                });
            });
        }
    </script>

    <!-- Footer -->
    <footer class="bg-gray-900 text-gray-400 mt-16">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
            <div class="flex flex-col md:flex-row justify-between items-center gap-4">
                <div class="flex items-center gap-2">
                    <div class="w-7 h-7 bg-gradient-to-br from-emerald-500 to-teal-600 rounded-lg flex items-center justify-center">
                        <i class="fas fa-leaf text-white text-xs"></i>
                    </div>
                    <span class="font-bold text-white">JeevBandhu</span>
                </div>
                <p class="text-sm">&copy; 2026 JeevBandhu. Ensuring Bio-Safe Livestock Products.</p>
                <div class="flex gap-4 text-sm">
                    <a href="/marketplace" class="hover:text-emerald-400 transition">Marketplace</a>
                    <a href="/guide/medicine-guide" class="hover:text-emerald-400 transition">Guide</a>
                    <a href="/community" class="hover:text-emerald-400 transition">Community</a>
                </div>
            </div>
        </div>
    </footer>
</body>

</html>
